# Probe agents (lib/agent.ts)
# Prefer Vercel AI Gateway (unifies billing); falls back to direct OpenAI.
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=

# Patcher (lib/patcher/*) — required for live PR creation
# Create a GitHub App with Contents:RW + PullRequests:RW + Metadata:R,
# install it on the target repo, then set:
GITHUB_APP_ID=
# PEM-formatted private key. Either inline (with \n) or set GITHUB_APP_PRIVATE_KEY_PATH.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# Vercel Sandbox auth — auto-pulled by `vercel env pull` once the project is linked.
# Either VERCEL_OIDC_TOKEN (preferred) or the team/project/token trio.
VERCEL_OIDC_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# Patcher behavior
# Set to "1" to skip the push/PR step and only log the diff (useful for prompt iteration).
PATCHER_DRY_RUN=
